# =============================================================
#  EIAAW AI Ads Agency — env.example
# =============================================================
# Per the EIAAW Deploy Contract, every production secret is resolved
# from Infisical at server boot. The values you see below as
# `secret://...` handles are looked up by instrumentation.ts and
# rewritten into process.env before the first request.
#
# Local dev: copy to .env.local and either
#   (a) leave INFISICAL_RESOLVER_ENABLED=false and replace handles
#       with raw test values, OR
#   (b) set INFISICAL_RESOLVER_ENABLED=true with the bootstrap creds
#       below to fetch real (or staging) values from Infisical.
#
# Production (Railway): only the bootstrap block + Railway-injected
# DB URLs are raw. Everything else is a handle. Never paste a raw
# production secret into Railway env.
# =============================================================

# === Bootstrap (the ONLY raw production secrets) ===
# Machine identity used by instrumentation.ts to authenticate with
# Infisical. Create in Infisical → Project Settings → Machine Identities.
# Grant `secrets:read` scoped to the project.
INFISICAL_RESOLVER_ENABLED=false
INFISICAL_SITE_URL=https://app.infisical.com
INFISICAL_PROJECT_ID=
INFISICAL_APP_CLIENT_ID=
INFISICAL_APP_CLIENT_SECRET=

# === Core (non-secret runtime config) ===
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Database (Railway Postgres — raw connection strings) ===
DATABASE_URL=postgresql://user:pass@host:5432/eiaaw?schema=public
DIRECT_URL=postgresql://user:pass@host:5432/eiaaw?schema=public

# === Auth ===
AUTH_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/AUTH_SECRET
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=secret://eiaaw-ai-ads-agency-prod/prod/AUTH_GOOGLE_ID
AUTH_GOOGLE_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/AUTH_GOOGLE_SECRET

# === Anthropic (agent brain) ===
ANTHROPIC_API_KEY=secret://eiaaw-ai-ads-agency-prod/prod/ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# === Stripe (subscriptions) ===
STRIPE_SECRET_KEY=secret://eiaaw-ai-ads-agency-prod/prod/STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/STRIPE_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me_at_build_time
STRIPE_PRICE_STARTER=secret://eiaaw-ai-ads-agency-prod/prod/STRIPE_PRICE_STARTER
STRIPE_PRICE_GROWTH=secret://eiaaw-ai-ads-agency-prod/prod/STRIPE_PRICE_GROWTH
STRIPE_PRICE_ENTERPRISE=secret://eiaaw-ai-ads-agency-prod/prod/STRIPE_PRICE_ENTERPRISE

# === Platform Ad APIs ===
# Set the OAuth client ID + secret in Infisical for each platform you
# go live with. Until then the adapters fall back to sandbox mode.
META_APP_ID=secret://eiaaw-ai-ads-agency-prod/prod/integrations/meta/META_APP_ID
META_APP_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/integrations/meta/META_APP_SECRET
META_REDIRECT_URI=
GOOGLE_ADS_CLIENT_ID=secret://eiaaw-ai-ads-agency-prod/prod/integrations/google/GOOGLE_ADS_CLIENT_ID
GOOGLE_ADS_CLIENT_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/integrations/google/GOOGLE_ADS_CLIENT_SECRET
GOOGLE_ADS_DEVELOPER_TOKEN=secret://eiaaw-ai-ads-agency-prod/prod/integrations/google/GOOGLE_ADS_DEVELOPER_TOKEN
TIKTOK_APP_ID=secret://eiaaw-ai-ads-agency-prod/prod/integrations/tiktok/TIKTOK_APP_ID
TIKTOK_APP_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/integrations/tiktok/TIKTOK_APP_SECRET
LINKEDIN_CLIENT_ID=secret://eiaaw-ai-ads-agency-prod/prod/integrations/linkedin/LINKEDIN_CLIENT_ID
LINKEDIN_CLIENT_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/integrations/linkedin/LINKEDIN_CLIENT_SECRET
MICROSOFT_CLIENT_ID=secret://eiaaw-ai-ads-agency-prod/prod/integrations/microsoft/MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/integrations/microsoft/MICROSOFT_CLIENT_SECRET
MICROSOFT_DEVELOPER_TOKEN=secret://eiaaw-ai-ads-agency-prod/prod/integrations/microsoft/MICROSOFT_DEVELOPER_TOKEN
YOUTUBE_CLIENT_ID=secret://eiaaw-ai-ads-agency-prod/prod/integrations/youtube/YOUTUBE_CLIENT_ID
YOUTUBE_CLIENT_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/integrations/youtube/YOUTUBE_CLIENT_SECRET
APPLE_ADS_ORG_ID=secret://eiaaw-ai-ads-agency-prod/prod/integrations/apple/APPLE_ADS_ORG_ID
APPLE_ADS_KEY_ID=secret://eiaaw-ai-ads-agency-prod/prod/integrations/apple/APPLE_ADS_KEY_ID
APPLE_ADS_PRIVATE_KEY=secret://eiaaw-ai-ads-agency-prod/prod/integrations/apple/APPLE_ADS_PRIVATE_KEY

# === Token encryption (AES-256-GCM) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EIAAW_ENCRYPTION_KEY=secret://eiaaw-ai-ads-agency-prod/prod/EIAAW_ENCRYPTION_KEY

# === AI cost circuit breaker override (emergency) ===
EIAAW_COST_OVERRIDE_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/EIAAW_COST_OVERRIDE_SECRET

# === Rate limiting (production) ===
UPSTASH_REDIS_REST_URL=secret://eiaaw-ai-ads-agency-prod/prod/UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=secret://eiaaw-ai-ads-agency-prod/prod/UPSTASH_REDIS_REST_TOKEN

# === Durable job worker ===
EIAAW_WORKER_SECRET=secret://eiaaw-ai-ads-agency-prod/prod/EIAAW_WORKER_SECRET

# === Observability ===
SENTRY_DSN=secret://eiaaw-ai-ads-agency-prod/prod/SENTRY_DSN
